# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).
#
# 1. Sign in at https://my.telegram.org with your phone number.
# 2. Open "API development tools" and create an app (any name; platform = Desktop).
# 3. Copy the "App api_id" and "App api_hash" shown there into the two values below.
#
# These identify YOUR client app to Telegram — the same kind of credential the
# official Telegram Desktop / Web clients use. They are NOT your login; logging
# in is a separate one-time step (`telegram-auth login`).

TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# OPTIONAL. Pre-fill your phone number (international format, e.g. +14155550123)
# so `telegram-auth login` doesn't prompt for it. You can also just type it at
# the prompt instead of setting this.
# TELEGRAM_PHONE=+14155550123

# OPTIONAL. Where to keep local state (the encrypted session lives in your OS
# keyring; this dir only holds an encrypted fallback if no keyring is available).
# Defaults to ~/.telegram-briefing-mcp
# TELEGRAM_BRIEFING_HOME=~/.telegram-briefing-mcp
